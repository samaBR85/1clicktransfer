<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ===== Botao flat (padrao) ===== -->
  <Style Selector="Button">
    <Setter Property="Background" Value="{DynamicResource FlatBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FlatHoverBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
  </Style>
  <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource FlatHoverBrush}"/>
  </Style>
  <Style Selector="Button:disabled">
    <Setter Property="Opacity" Value="0.5"/>
  </Style>

  <!-- ===== Botao primario (TRANSFERIR) — classe "primary" (NAO usar "accent":
       colide com o estilo embutido do Fluent que usa o accent do sistema). ===== -->
  <Style Selector="Button.primary">
    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="CornerRadius" Value="14"/>
    <Setter Property="FontWeight" Value="Bold"/>
  </Style>
  <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
  </Style>

  <!-- ===== ToggleButton flat (Watch) ===== -->
  <Style Selector="ToggleButton.toggle-flat">
    <Setter Property="Background" Value="{DynamicResource FlatBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="8"/>
    <Setter Property="Padding" Value="8,0"/>
    <Setter Property="Cursor" Value="Hand"/>
  </Style>
  <Style Selector="ToggleButton.toggle-flat:checked /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
    <Setter Property="TextElement.Foreground" Value="{DynamicResource AccentTextBrush}"/>
  </Style>

  <!-- ===== TextBox ===== -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource InputBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
    <Setter Property="CornerRadius" Value="6"/>
  </Style>

  <!-- ===== ToolTip escuro/legivel ===== -->
  <Style Selector="ToolTip">
    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="6"/>
    <Setter Property="Padding" Value="9,5"/>
  </Style>

  <!-- ===== ListBox ===== -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
  </Style>

  <!-- ===== DataGrid ===== -->
  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LineBrush}"/>
    <Setter Property="RowBackground" Value="Transparent"/>
  </Style>
  <Style Selector="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource GridHeaderBrush}"/>
    <Setter Property="Foreground" Value="{DynamicResource SubTextBrush}"/>
  </Style>

</Styles>
