<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OneClickTransfer.Avalonia.ViewModels"
        x:Class="OneClickTransfer.Avalonia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="{Binding Title}"
        Icon="/Assets/app.ico"
        Width="820" Height="720" MinWidth="660" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgBrush}">

  <Window.Resources>
    <!-- Ícones funcionais como StreamGeometry (Segoe MDL2/emoji não existem no Linux). -->
    <StreamGeometry x:Key="IcoRefresh">M17.65 6.35A7.958 7.958 0 0 0 12 4a8 8 0 1 0 7.75 10h-2.08A6 6 0 1 1 12 6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z</StreamGeometry>
    <StreamGeometry x:Key="IcoEye">M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17a5 5 0 1 1 0-10 5 5 0 0 1 0 10zm0-8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z</StreamGeometry>
    <StreamGeometry x:Key="IcoPlus">M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z</StreamGeometry>
    <StreamGeometry x:Key="IcoCopy">M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z</StreamGeometry>
    <StreamGeometry x:Key="IcoPencil">M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34a.9959.9959 0 0 0-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z</StreamGeometry>
    <StreamGeometry x:Key="IcoTrash">M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z</StreamGeometry>
    <StreamGeometry x:Key="IcoGear">M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z</StreamGeometry>
    <StreamGeometry x:Key="IcoPlay">M8 5v14l11-7z</StreamGeometry>
    <StreamGeometry x:Key="IcoClock">M12 2a10 10 0 1 0 .001 20.001A10 10 0 0 0 12 2zm0 18a8 8 0 1 1 .001-16.001A8 8 0 0 1 12 20zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z</StreamGeometry>
  </Window.Resources>

  <Grid x:Name="RootGrid" Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>                                   <!-- 0 top bar -->
      <RowDefinition Height="138" MinHeight="120"/>                    <!-- 1 TAREFAS -->
      <RowDefinition Height="Auto"/>                                   <!-- 2 splitter -->
      <RowDefinition Height="*"/>                                      <!-- 3 cards -->
      <RowDefinition Height="Auto"/>                                   <!-- 4 acao -->
      <RowDefinition Height="Auto"/>                                   <!-- 5 TRANSFERIR -->
      <RowDefinition Height="Auto"/>                                   <!-- 6 progress -->
      <RowDefinition Height="Auto"/>                                   <!-- 7 status -->
      <RowDefinition Height="Auto"/>                                   <!-- 8 taxa -->
      <RowDefinition Height="Auto"/>                                   <!-- 9 fila de transferencia -->
      <RowDefinition Height="Auto"/>                                   <!-- 10 rodape -->
    </Grid.RowDefinitions>

    <!-- Top bar: título + engrenagem de Configurações -->
    <Grid Grid.Row="0" Margin="0,0,0,8" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding Title}" FontSize="16" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
      <Button Grid.Column="1" Width="30" Height="28" Padding="0" Command="{Binding OpenSettingsCommand}"
              IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding SettingsLabel}"
              AutomationProperties.Name="{Binding SettingsLabel}">
        <PathIcon Data="{StaticResource IcoGear}" Width="16" Height="16"/>
      </Button>
    </Grid>

    <!-- Tarefas: lista (esquerda) + painel de ações da selecionada (direita) -->
    <Grid Grid.Row="1" ColumnDefinitions="1.45*,10,1*">

      <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="8,6">
        <DockPanel>
          <Grid DockPanel.Dock="Top" Margin="2,0,0,4">
            <TextBlock Text="{Binding TasksHeader}" FontWeight="Bold" FontSize="11"
                       Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
              <Button Width="24" Height="24" Padding="0" Command="{Binding NewJobCommand}" IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding NewLabel}" AutomationProperties.Name="{Binding NewLabel}">
                <PathIcon Data="{StaticResource IcoPlus}" Width="14" Height="14"/>
              </Button>
              <Button Width="24" Height="24" Padding="0" Command="{Binding DuplicateJobCommand}" IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding DuplicateLabel}" AutomationProperties.Name="{Binding DuplicateLabel}">
                <PathIcon Data="{StaticResource IcoCopy}" Width="13" Height="13"/>
              </Button>
              <Button Width="24" Height="24" Padding="0" Command="{Binding RenameJobCommand}" IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding RenameLabel}" AutomationProperties.Name="{Binding RenameLabel}">
                <PathIcon Data="{StaticResource IcoPencil}" Width="13" Height="13"/>
              </Button>
              <Button Width="24" Height="24" Padding="0" Command="{Binding RemoveJobCommand}" IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding RemoveLabel}" AutomationProperties.Name="{Binding RemoveLabel}">
                <PathIcon Data="{StaticResource IcoTrash}" Width="13" Height="13"/>
              </Button>
            </StackPanel>
          </Grid>
          <ListBox x:Name="LstJobs" MinHeight="44" ItemsSource="{Binding Jobs}"
                   SelectedIndex="{Binding SelectedJobIndex, Mode=TwoWay}"
                   DoubleTapped="Jobs_DoubleTapped"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.Styles>
              <Style Selector="ListBoxItem">
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="MinHeight" Value="0"/>
              </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:JobItemViewModel">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                            IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Summary}" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <TextBlock Grid.Column="2" Text="{Binding WatchIcon}" VerticalAlignment="Center"
                             Margin="8,0,4,0" FontSize="13"/>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- Painel da tarefa selecionada -->
      <Border Grid.Column="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12,10">
        <DockPanel>
          <StackPanel DockPanel.Dock="Bottom" Spacing="5">
            <Button Classes="primary" Height="30" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding TransferSelectedCommand}" IsEnabled="{Binding CanTransferSelected}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IcoPlay}" Width="13" Height="13"/>
                <TextBlock Text="{Binding SendThisTaskLabel}" FontSize="12"/>
              </StackPanel>
            </Button>
            <Button Height="28" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding EditTaskCommand}" IsEnabled="{Binding NotTransferring}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <PathIcon Data="{StaticResource IcoPencil}" Width="12" Height="12"/>
                <TextBlock Text="{Binding EditTaskLabel}" FontSize="12"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <StackPanel VerticalAlignment="Top">
            <TextBlock Text="{Binding SelectedJobName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding SelectedJobFilesText}" FontSize="11" Foreground="{DynamicResource SubTextBrush}" Margin="0,3,0,0"/>
            <TextBlock Text="{Binding SelectedJobDestsText}" FontSize="11" Foreground="{DynamicResource SubTextBrush}"/>
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Divisor arrastavel: altura do painel TAREFAS -->
    <GridSplitter Grid.Row="2" Height="7" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                  Margin="0,0,0,5" Background="Transparent" ResizeDirection="Rows"
                  Cursor="SizeNorthSouth" DragCompleted="TasksSplitter_DragCompleted"/>

    <!-- Cards -->
    <Grid x:Name="CardsGrid" Grid.Row="3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="200"/>
        <ColumnDefinition Width="14"/>
        <ColumnDefinition Width="*" MinWidth="200"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="1" Width="2" HorizontalAlignment="Center" Background="{DynamicResource LineBrush}" IsHitTestVisible="False"/>
      <GridSplitter Grid.Column="1" Width="14" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="Transparent" ResizeDirection="Columns" DragCompleted="Splitter_DragCompleted"/>

      <!-- Source card -->
      <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="10">
        <DockPanel>
          <Grid DockPanel.Dock="Top">
            <TextBlock Text="{Binding SourceHeader}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="5">
              <Button Width="26" Height="24" Padding="0" Command="{Binding Source.RefreshCommand}"
                      IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding RefreshTip}"
                      AutomationProperties.Name="{Binding RefreshTip}">
                <PathIcon Data="{StaticResource IcoRefresh}" Width="13" Height="13"/>
              </Button>
              <ToggleButton Classes="toggle-flat" Width="30" Height="24"
                            IsChecked="{Binding IsWatchChecked, Mode=TwoWay}" ToolTip.Tip="{Binding WatchTip}"
                            AutomationProperties.Name="{Binding WatchTip}">
                <PathIcon Data="{StaticResource IcoEye}" Width="14" Height="14"/>
              </ToggleButton>
            </StackPanel>
          </Grid>
          <TextBlock Text="{Binding Source.PathText}" DockPanel.Dock="Top" FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                     TextTrimming="CharacterEllipsis" Margin="0,3,0,6"/>
          <DataGrid x:Name="GridSrc" ItemsSource="{Binding Source.Rows}" IsReadOnly="True"
                    CanUserSortColumns="False" CanUserResizeColumns="True" HeadersVisibility="Column"
                    SelectionMode="Single" SelectionChanged="Grid_SelectionCleared"
                    DoubleTapped="GridSrc_DoubleTapped">
            <DataGrid.Styles>
              <Style Selector="DataGridRow" x:DataType="vm:FileRow">
                <Setter Property="Classes.hl" Value="{Binding Highlight}"/>
              </Style>
              <Style Selector="DataGridRow.hl">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
              </Style>
              <Style Selector="DataGridRow.hl DataGridCell TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
              <DataGridTextColumn Header="{Binding ColName}" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="{Binding ColSize}" Binding="{Binding Size}" Width="80"/>
              <DataGridTextColumn Header="{Binding ColModified}" Binding="{Binding Modified}" Width="115"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- Destination card -->
      <Border Grid.Column="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="10">
        <DockPanel>
          <Grid DockPanel.Dock="Top">
            <TextBlock Text="{Binding DestHeader}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
            <Button Width="26" Height="24" Padding="0" HorizontalAlignment="Right" Command="{Binding Dest.RefreshCommand}"
                    IsEnabled="{Binding NotTransferring}" ToolTip.Tip="{Binding RefreshTip}"
                    AutomationProperties.Name="{Binding RefreshTip}">
              <PathIcon Data="{StaticResource IcoRefresh}" Width="13" Height="13"/>
            </Button>
          </Grid>
          <TextBlock Text="{Binding Dest.PathText}" DockPanel.Dock="Top" FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                     TextTrimming="CharacterEllipsis" Margin="0,3,0,6"/>
          <DataGrid x:Name="GridDst" ItemsSource="{Binding Dest.Rows}" IsReadOnly="True"
                    CanUserSortColumns="False" CanUserResizeColumns="True" HeadersVisibility="Column"
                    SelectionMode="Single" SelectionChanged="Grid_SelectionCleared"
                    DoubleTapped="GridDst_DoubleTapped" ContextRequested="GridDst_ContextRequested">
            <DataGrid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{Binding CtxCreateFolderLabel}" Command="{Binding CreateFolderInDestCommand}">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IcoPlus}" Width="13" Height="13"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding CtxRenameLabel}" Click="CtxRename_Click">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IcoPencil}" Width="13" Height="13"/></MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{Binding CtxDeleteLabel}" Click="CtxDelete_Click">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IcoTrash}" Width="13" Height="13"/></MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{Binding CtxCopyPathLabel}" Click="CtxCopyPath_Click">
                  <MenuItem.Icon><PathIcon Data="{StaticResource IcoCopy}" Width="13" Height="13"/></MenuItem.Icon>
                </MenuItem>
              </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
              <DataGridTextColumn Header="{Binding ColName}" Binding="{Binding Name}" Width="*"/>
              <DataGridTextColumn Header="{Binding ColSize}" Binding="{Binding Size}" Width="80"/>
              <DataGridTextColumn Header="{Binding ColModified}" Binding="{Binding Modified}" Width="115"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>
    </Grid>

    <!-- Action -->
    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="2,10,0,0">
      <TextBlock Text="{Binding ActionLabel}" FontSize="12" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
      <RadioButton GroupName="act" Content="{Binding ReplaceLabel}" FontSize="12" VerticalAlignment="Center"
                   IsChecked="{Binding OverwriteAlways, Mode=TwoWay}"/>
      <RadioButton GroupName="act" Content="{Binding ReplaceIfNewerLabel}" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"
                   IsChecked="{Binding OverwriteIfNewer, Mode=TwoWay}"/>
      <RadioButton GroupName="act" Content="{Binding DontReplaceLabel}" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"
                   IsChecked="{Binding OverwriteNever, Mode=TwoWay}"/>
    </StackPanel>

    <!-- Transfer -->
    <Button Grid.Row="5" Classes="primary" Content="{Binding TransferLabel}"
            Height="46" FontSize="15" Margin="0,10,0,0" HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center" Command="{Binding TransferCommand}" IsEnabled="{Binding CanGo}"/>

    <!-- Progress -->
    <ProgressBar Grid.Row="6" Height="6" Minimum="0" Maximum="100" Value="{Binding ProgressValue}"
                 Margin="0,8,0,0" Background="{DynamicResource InputBrush}" Foreground="{DynamicResource AccentBrush}"/>

    <!-- Status -->
    <TextBlock Grid.Row="7" Text="{Binding StatusText}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="12"
               Margin="0,8,0,0" Foreground="{DynamicResource SubTextBrush}"
               Classes.success="{Binding StatusSuccess}" Classes.error="{Binding StatusError}"/>

    <!-- Taxa -->
    <TextBlock Grid.Row="8" Text="{Binding RateText}" HorizontalAlignment="Center" FontSize="11"
               Margin="0,3,0,0" Foreground="{DynamicResource SubTextBrush}"/>

    <!-- Fila de transferência -->
    <Border Grid.Row="9" Margin="0,10,0,0" Padding="12,10" IsVisible="{Binding HasQueueActivity}"
            Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource AccentBrush}"
            BorderThickness="1" CornerRadius="8">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{Binding QueuePanelTitle}" FontWeight="Bold" FontSize="11"
                   Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,6"/>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="4" Margin="0,0,0,6">
          <Button Classes="tab" Content="{Binding QueueTabQueuedLabel}" Command="{Binding SelectQueueQueuedTabCommand}"
                  Classes.active="{Binding IsQueueTabActive}"/>
          <Button Classes="tab" Content="{Binding QueueTabFailedLabel}" Command="{Binding SelectQueueFailedTabCommand}"
                  Classes.active="{Binding IsFailedTabActive}"/>
          <Button Classes="tab" Content="{Binding QueueTabSucceededLabel}" Command="{Binding SelectQueueSucceededTabCommand}"
                  Classes.active="{Binding IsSucceededTabActive}"/>
        </StackPanel>

        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
          <Button DockPanel.Dock="Right" Content="{Binding QueueClearCompletedLabel}" FontSize="11"
                  Command="{Binding ClearCompletedQueueCommand}" IsEnabled="{Binding CanClearCompletedQueue}"/>
          <TextBlock Text="{Binding QueueTotalText}" FontSize="11" VerticalAlignment="Center"
                     Foreground="{DynamicResource SubTextBrush}"/>
        </DockPanel>

        <DataGrid x:Name="GridQueue" ItemsSource="{Binding ActiveQueueItems}" IsReadOnly="True"
                  CanUserSortColumns="False" CanUserResizeColumns="True" HeadersVisibility="Column"
                  SelectionMode="Single" SelectionChanged="Grid_SelectionCleared" MaxHeight="140">
          <DataGrid.Styles>
            <Style Selector="DataGridRow" x:DataType="vm:TransferQueueItem">
              <Setter Property="Classes.failed" Value="{Binding IsFailed}"/>
            </Style>
            <Style Selector="DataGridRow.failed DataGridCell TextBlock">
              <Setter Property="Foreground" Value="#E24B4A"/>
            </Style>
          </DataGrid.Styles>
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="{Binding QueueColName}" Width="*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:TransferQueueItem">
                  <TextBlock Text="{Binding DisplayName}" FontSize="11.5" VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding TooltipText}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="{Binding QueueColProgress}" Width="180">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="vm:TransferQueueItem">
                  <StackPanel VerticalAlignment="Center" IsVisible="{Binding IsActive}" Spacing="2">
                    <ProgressBar Height="4" Minimum="0" Maximum="100" Value="{Binding Progress}"
                                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="{DynamicResource SubTextBrush}"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="{Binding QueueColSize}" Binding="{Binding SizeText}" Width="80"/>
            <DataGridTextColumn Header="{Binding QueueColTime}" Binding="{Binding TimeText}" Width="90"/>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Border>

    <!-- Footer -->
    <Grid Grid.Row="10" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding HintText}" FontSize="12"
                 Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center"
                  IsVisible="{Binding HasLastTransfer}">
        <PathIcon Data="{StaticResource IcoClock}" Width="12" Height="12"
                  Foreground="{DynamicResource SubTextBrush}"/>
        <TextBlock Text="{Binding LastTransferText}" FontSize="12"
                   Foreground="{DynamicResource SubTextBrush}"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
