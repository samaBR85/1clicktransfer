<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OneClickTransfer.Avalonia.Views.PromptDialog"
        Width="420" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">
  <StackPanel Margin="18" Spacing="12">
    <TextBlock x:Name="LabelText" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>
    <TextBox x:Name="Input"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button x:Name="OkButton" Classes="primary" Content="OK" Width="100" Height="34" Click="Ok_Click"/>
      <Button x:Name="CancelButton" Content="Cancelar" Width="100" Height="34" Click="Cancel_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
