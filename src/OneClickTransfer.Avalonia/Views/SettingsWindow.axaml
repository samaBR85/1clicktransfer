<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OneClickTransfer.Avalonia.ViewModels"
        x:Class="OneClickTransfer.Avalonia.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="{Binding Title}"
        Icon="/Assets/app.ico"
        Width="470" Height="590"
        WindowStartupLocation="CenterOwner" CanResize="False"
        Background="{DynamicResource BgBrush}">

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,14,0,0">
      <Button Classes="primary" Width="108" Height="32" Content="{Binding SaveLabel}" Command="{Binding SaveCommand}"/>
      <Button Width="96" Height="32" Content="{Binding CancelLabel}" Command="{Binding CancelCommand}"/>
    </StackPanel>

    <StackPanel>
      <TextBlock Text="{Binding GeneralSection}" FontWeight="SemiBold" Margin="0,0,0,10"/>
      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock Text="{Binding MaxParallelLabel}" FontSize="12"/>
          <TextBlock Text="{Binding MaxParallelHint}" FontSize="10.5" Foreground="{DynamicResource SubTextBrush}" Margin="0,2,0,8"/>
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Slider Width="220" Minimum="1" Maximum="8" TickFrequency="1" IsSnapToTickEnabled="True"
                    Value="{Binding MaxParallelDestinations, Mode=TwoWay}"/>
            <Border Width="34" Height="28" Background="{DynamicResource InputBrush}" CornerRadius="6"
                    BorderBrush="{DynamicResource LineBrush}" BorderThickness="1">
              <TextBlock Text="{Binding MaxParallelDestinations}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
            </Border>
          </StackPanel>
          <CheckBox Margin="0,10,0,0" Content="{Binding MinimizeToTrayLabel}" IsChecked="{Binding MinimizeToTrayOnClose, Mode=TwoWay}"/>
          <CheckBox Margin="23,6,0,0" Content="{Binding KeepWatchMinimizedLabel}"
                    IsChecked="{Binding KeepWatchWhileMinimized, Mode=TwoWay}"
                    IsVisible="{Binding MinimizeToTrayOnClose}"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding Sec3}" FontWeight="SemiBold" Margin="0,0,0,10"/>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
        <TextBlock Text="{Binding LangLabelText}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox Width="150" ItemsSource="{Binding LangOptions}" SelectedIndex="{Binding SelectedLangIndex, Mode=TwoWay}"/>
        <TextBlock Text="{Binding ThemeLabelText}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="24,0,8,0"/>
        <ComboBox Width="140" ItemsSource="{Binding ThemeOptions}" SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"/>
      </StackPanel>

      <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
        <TextBlock Text="{Binding ShortcutLabelText}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
        <ComboBox Width="150" ItemsSource="{Binding KeyOptions}" SelectedItem="{Binding SelectedKey, Mode=TwoWay}"/>
        <TextBlock Text="{Binding F5Note}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="11"/>
      </StackPanel>

      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12">
        <StackPanel Orientation="Horizontal">
          <Button Height="30" Padding="14,0" Content="{Binding CheckUpdateLabel}" Command="{Binding CheckUpdateCommand}" IsEnabled="{Binding !CheckingUpdate}"/>
          <CheckBox VerticalAlignment="Center" Margin="14,0,0,0" Content="{Binding AutoUpdateLabel}" IsChecked="{Binding AutoUpdateCheck, Mode=TwoWay}"/>
          <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="16,0,0,0" FontSize="11"/>
        </StackPanel>
      </Border>

      <!-- About -->
      <TextBlock Text="{Binding AboutLabel}" FontWeight="SemiBold" Margin="0,16,0,6"/>
      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12">
        <DockPanel>
          <Button DockPanel.Dock="Right" Classes="link" VerticalAlignment="Center"
                  Content="{Binding GithubLabel}" Command="{Binding OpenGithubCommand}"
                  ToolTip.Tip="https://github.com/samaBR85/1clicktransfer"/>
          <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Text="{Binding AuthorText}"
                     Foreground="{DynamicResource SubTextBrush}" FontSize="11.5" Margin="0,0,12,0"/>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding AppNameText}" FontWeight="SemiBold"/>
            <TextBlock Text="{Binding VersionText}" Foreground="{DynamicResource SubTextBrush}" FontSize="11"/>
          </StackPanel>
        </DockPanel>
      </Border>
    </StackPanel>
  </DockPanel>
</Window>
