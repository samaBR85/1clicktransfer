<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OneClickTransfer.Avalonia.ViewModels"
        x:Class="OneClickTransfer.Avalonia.Views.DestinationEditorWindow"
        x:DataType="vm:DestinationEditorViewModel"
        Title="{Binding WindowTitle}"
        Width="540" Height="516"
        WindowStartupLocation="CenterOwner" CanResize="False" ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}">

  <DockPanel Margin="16">
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,12,0,0">
      <Button Classes="primary" Width="108" Height="32" Content="{Binding SaveLabel}" Command="{Binding OkCommand}"/>
      <Button Width="96" Height="32" Content="{Binding CancelLabel}" Command="{Binding CancelCommand}"/>
    </StackPanel>

    <StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="22" Margin="0,0,0,10">
        <RadioButton GroupName="dt" Content="{Binding LocalLabel}" IsChecked="{Binding IsLocal, Mode=TwoWay}" VerticalAlignment="Center"/>
        <RadioButton GroupName="dt" Content="{Binding FtpLabel}" IsChecked="{Binding IsFtp, Mode=TwoWay}" VerticalAlignment="Center"/>
        <RadioButton GroupName="dt" Content="{Binding SftpLabel}" IsChecked="{Binding IsSftp, Mode=TwoWay}" VerticalAlignment="Center"/>
      </StackPanel>

      <CheckBox Content="{Binding VerifyLabel}" IsChecked="{Binding VerifyAfterTransfer, Mode=TwoWay}" Margin="0,0,0,10"/>

      <!-- Local -->
      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12"
              IsEnabled="{Binding IsLocal}" Opacity="{Binding LocalOpacity}">
        <StackPanel>
          <TextBlock Text="{Binding DstFolderLabel}" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
          <DockPanel>
            <Button DockPanel.Dock="Right" Width="108" Height="30" Margin="8,0,0,0"
                    Content="{Binding BrowseLabel}" Command="{Binding BrowseLocalCommand}"/>
            <TextBox Height="30" Text="{Binding LocalFolder, Mode=TwoWay}"/>
          </DockPanel>
        </StackPanel>
      </Border>

      <!-- FTP / SFTP -->
      <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
              BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0"
              IsEnabled="{Binding IsServer}" Opacity="{Binding ServerOpacity}">
        <Grid RowSpacing="6" ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="105"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="118"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding SavedServerLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <ComboBox Grid.Row="0" Grid.Column="1" Height="30" ItemsSource="{Binding SavedServerOptions}"
                    SelectedIndex="{Binding SelectedSavedServerIndex, Mode=TwoWay}"/>
          <Button Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1" Height="30" Padding="4,0" FontSize="11"
                  Content="{Binding SaveServerLabel}" Command="{Binding SavedServerSaveCommand}"/>
          <Button Grid.Row="0" Grid.Column="3" Height="30" Padding="4,0" FontSize="11"
                  Content="{Binding DeleteServerLabel}" Command="{Binding SavedServerDeleteCommand}"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding HostLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <TextBox Grid.Row="1" Grid.Column="1" Height="30" Text="{Binding Host, Mode=TwoWay}"/>
          <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding PortLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <TextBox Grid.Row="1" Grid.Column="3" Height="30" Text="{Binding Port, Mode=TwoWay}"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding RemoteLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Height="30" Text="{Binding RemoteFolder, Mode=TwoWay}"/>
          <Button Grid.Row="2" Grid.Column="3" Height="30" Content="{Binding BrowseRemoteLabel}" Command="{Binding BrowseRemoteCommand}"/>

          <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding UserLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <TextBox Grid.Row="3" Grid.Column="1" Height="30" Text="{Binding Username, Mode=TwoWay}"/>
          <StackPanel Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Spacing="4"
                      VerticalAlignment="Center" IsVisible="{Binding ShowTls}">
            <CheckBox Content="{Binding TlsLabel}" IsChecked="{Binding UseTls, Mode=TwoWay}"/>
            <CheckBox Content="{Binding PasvLabel}" IsChecked="{Binding ForceLegacyPasv, Mode=TwoWay}"/>
          </StackPanel>

          <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding PassLabel}" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
          <TextBox Grid.Row="4" Grid.Column="1" Height="30" PasswordChar="●" Text="{Binding Password, Mode=TwoWay}"/>
          <Button Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Height="30"
                  Content="{Binding TestLabel}" Command="{Binding TestCommand}" IsEnabled="{Binding !Testing}"/>

          <TextBlock Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Text="{Binding TestResult}" Margin="0,4,0,0"
                     FontSize="11" TextAlignment="Center" TextTrimming="CharacterEllipsis"
                     Foreground="{DynamicResource SubTextBrush}"
                     Classes.success="{Binding TestOk}" Classes.error="{Binding TestError}"/>
        </Grid>
      </Border>
    </StackPanel>
  </DockPanel>
</Window>
