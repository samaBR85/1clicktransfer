<Window x:Class="OneClickTransfer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="740" Width="580"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BgBrush}" FontFamily="Segoe UI" FontSize="13">
    <DockPanel Margin="18">
        <!-- Botoes (rodape) -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="BtnSave" Width="110" Height="34" Style="{StaticResource AccentButton}" Click="Save_Click"/>
            <Button x:Name="BtnCancel" Width="100" Height="34" Margin="10,0,0,0" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>

        <StackPanel>
            <!-- 1) Arquivo -->
            <TextBlock x:Name="LblSec1" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <DockPanel>
                <Button x:Name="BtnBrowseSrc" DockPanel.Dock="Right" Width="110" Height="30" Margin="8,0,0,0" Click="BrowseSrc_Click"/>
                <TextBox x:Name="TxtSrc" Height="30" VerticalContentAlignment="Center"/>
            </DockPanel>

            <!-- 2) Destino -->
            <TextBlock x:Name="LblSec2" FontWeight="SemiBold" Margin="0,18,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton x:Name="RbLocal" GroupName="dest" Checked="DestType_Changed" VerticalAlignment="Center"/>
                <RadioButton x:Name="RbFtp" GroupName="dest" Checked="DestType_Changed" VerticalAlignment="Center" Margin="24,0,0,0"/>
            </StackPanel>

            <!-- Painel local -->
            <Border x:Name="PanelLocal" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock x:Name="LblDstFolder" Foreground="{DynamicResource SubTextBrush}" Margin="0,0,0,4"/>
                    <DockPanel>
                        <Button x:Name="BtnBrowseDst" DockPanel.Dock="Right" Width="110" Height="30" Margin="8,0,0,0" Click="BrowseDst_Click"/>
                        <TextBox x:Name="TxtDstFolder" Height="30" VerticalContentAlignment="Center"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- Painel FTP -->
            <Border x:Name="PanelFtp" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="LblHost" Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtHost" Grid.Row="0" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,6"/>
                    <TextBlock x:Name="LblPort" Grid.Row="0" Grid.Column="2" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtPort" Grid.Row="0" Grid.Column="3" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,6"/>

                    <TextBlock x:Name="LblRemote" Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtRemote" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,6"/>
                    <Button x:Name="BtnBrowseRemote" Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,6" Click="BrowseRemote_Click"/>

                    <TextBlock x:Name="LblUser" Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtUser" Grid.Row="2" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,0,10,6"/>
                    <CheckBox x:Name="ChkTls" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" VerticalAlignment="Center" Margin="0,0,0,6"/>

                    <TextBlock x:Name="LblPass" Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="TxtPass" Grid.Row="3" Grid.Column="1" Height="30" Margin="0,0,10,0"/>
                    <Button x:Name="BtnTest" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Height="30" Click="Test_Click"/>
                </Grid>
            </Border>

            <!-- 3) Opcoes -->
            <TextBlock x:Name="LblSec3" FontWeight="SemiBold" Margin="0,18,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="LblShortcut" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbKey" Width="150" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblF5Note" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="14,0,0,0" FontSize="11.5"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LblTheme" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="CmbTheme" Width="140" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblLang" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="24,0,8,0"/>
                <ComboBox x:Name="CmbLang" Width="150" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 4) Perfis -->
            <Border Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="14,14,14,18" Margin="0,18,0,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock x:Name="LblProfiles" DockPanel.Dock="Left" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Button x:Name="BtnProfSave" DockPanel.Dock="Right" Width="150" Height="30" Margin="8,0,0,0" Click="ProfSave_Click"/>
                        <ComboBox x:Name="CmbProfiles" Height="30" SelectionChanged="Profiles_Changed"/>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnProfRename" Width="110" Height="30" Click="ProfRename_Click"/>
                        <Button x:Name="BtnProfDelete" Width="110" Height="30" Margin="8,0,0,0" Click="ProfDelete_Click"/>
                        <Button x:Name="BtnReset" Width="150" Height="30" Margin="8,0,0,0" Click="Reset_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
