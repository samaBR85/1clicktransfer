<Window x:Class="OneClickTransfer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="1-Click Transfer" Height="810" Width="900"
        MinWidth="740" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/app.ico"
        Background="{DynamicResource BgBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>                                  <!-- 0 top bar -->
            <RowDefinition x:Name="RowTasks" Height="150" MinHeight="140"/> <!-- 1 TAREFAS -->
            <RowDefinition Height="Auto"/>                                  <!-- 2 splitter horizontal -->
            <RowDefinition Height="*"/>                                     <!-- 3 cards -->
            <RowDefinition Height="Auto"/>                                  <!-- 4 acao -->
            <RowDefinition Height="Auto"/>                                  <!-- 5 TRANSFERIR -->
            <RowDefinition Height="Auto"/>                                  <!-- 6 ProgressBar -->
            <RowDefinition Height="Auto"/>                                  <!-- 7 status -->
            <RowDefinition Height="Auto"/>                                  <!-- 8 taxa -->
            <RowDefinition Height="Auto"/>                                  <!-- 9 rodape -->
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <TextBlock x:Name="TxtTitle" Text="1-Click Transfer" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Tarefas (multi origem -> destino) -->
        <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="10,8">
                <DockPanel>
                    <TextBlock x:Name="TxtTasksHdr" Text="TASKS" DockPanel.Dock="Top" FontWeight="Bold" FontSize="12"
                               Foreground="{DynamicResource SubTextBrush}" Margin="2,0,0,6"/>
                    <ListBox x:Name="LstJobs" MinHeight="52" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="Jobs_SelectionChanged" MouseDoubleClick="Jobs_DoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0"
                                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                                              Checked="JobEnabled_Changed" Unchecked="JobEnabled_Changed"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Summary}" FontSize="11" Foreground="{DynamicResource SubTextBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding WatchIcon}" VerticalAlignment="Center"
                                               Margin="8,0,6,0" FontSize="14"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Top">
                <Button x:Name="BtnJobNew" Width="112" Height="30" Margin="0,0,0,6" Click="JobNew_Click"/>
                <Button x:Name="BtnJobDup" Width="112" Height="30" Margin="0,0,0,6" Click="JobDuplicate_Click"/>
                <Button x:Name="BtnJobRen" Width="112" Height="30" Margin="0,0,0,6" Click="JobRename_Click"/>
                <Button x:Name="BtnJobDel" Width="112" Height="30" Click="JobRemove_Click"/>
            </StackPanel>
        </Grid>

        <!-- Divisor arrastavel: aumenta/diminui a altura do painel TAREFAS -->
        <GridSplitter Grid.Row="2" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Margin="0,0,0,6" Background="Transparent" ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Rows" Cursor="SizeNS" DragCompleted="TasksSplitter_DragCompleted"/>

        <!-- Cards -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColSrc" Width="*" MinWidth="220"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition x:Name="ColDst" Width="*" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- Divisor arrastavel entre os cards -->
            <Border Grid.Column="1" Width="2" HorizontalAlignment="Center" Background="{DynamicResource LineBrush}" IsHitTestVisible="False"/>
            <GridSplitter Grid.Column="1" Width="18" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          DragCompleted="Splitter_DragCompleted"/>

            <!-- Source card -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14">
                <DockPanel>
                    <Grid DockPanel.Dock="Top">
                        <TextBlock x:Name="TxtSrcHdr" Text="SOURCE" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnSrcRefresh" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" FontSize="14" Padding="0" Click="SrcRefresh_Click"/>
                            <ToggleButton x:Name="BtnWatch" Style="{StaticResource ToggleFlat}" Content="👁" Width="34" Height="26" FontSize="14" Margin="6,0,0,0" Click="Watch_Toggled"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="TxtSrcPath" DockPanel.Dock="Top" Foreground="{DynamicResource SubTextBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,8"/>
                    <DataGrid x:Name="GridSrc" MouseDoubleClick="GridSrc_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="SrcColName" Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn x:Name="SrcColSize" Header="Size" Binding="{Binding Size}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn x:Name="SrcColMod" Header="Modified" Binding="{Binding Modified}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Highlight}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Destination card -->
            <Border Grid.Column="2" Background="{DynamicResource CardBrush}" BorderBrush="{DynamicResource LineBrush}"
                    BorderThickness="1" CornerRadius="10" Padding="14">
                <DockPanel>
                    <Grid DockPanel.Dock="Top">
                        <TextBlock x:Name="TxtDstHdr" Text="DESTINATION" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        <Button x:Name="BtnDstRefresh" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" FontSize="14" Padding="0" HorizontalAlignment="Right" Click="DstRefresh_Click"/>
                    </Grid>
                    <TextBlock x:Name="TxtDstPath" DockPanel.Dock="Top" Foreground="{DynamicResource SubTextBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,8"/>
                    <DataGrid x:Name="GridDst" MouseDoubleClick="GridDst_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="DstColName" Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn x:Name="DstColSize" Header="Size" Binding="{Binding Size}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn x:Name="DstColMod" Header="Modified" Binding="{Binding Modified}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock"><Setter Property="HorizontalAlignment" Value="Right"/></Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Action -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="2,14,0,0">
            <TextBlock x:Name="TxtAction" Text="Action:" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center" Margin="0,0,14,0"/>
            <RadioButton x:Name="RbAlways" GroupName="act" Content="Replace" VerticalAlignment="Center" Checked="Overwrite_Changed"/>
            <RadioButton x:Name="RbIfNewer" GroupName="act" Content="Replace if newer" VerticalAlignment="Center" Margin="20,0,0,0" Checked="Overwrite_Changed"/>
            <RadioButton x:Name="RbNever" GroupName="act" Content="Don't replace" VerticalAlignment="Center" Margin="20,0,0,0" Checked="Overwrite_Changed"/>
        </StackPanel>

        <!-- Transfer -->
        <Button x:Name="BtnGo" Grid.Row="5" Style="{StaticResource AccentButton}" Content="TRANSFER"
                Height="70" FontSize="20" Margin="0,14,0,0" Click="BtnGo_Click"/>

        <!-- Progress -->
        <ProgressBar x:Name="Prog" Grid.Row="6" Height="8" Minimum="0" Maximum="100" Value="0"
                     Margin="0,10,0,0" BorderThickness="0"
                     Background="{DynamicResource InputBrush}" Foreground="{DynamicResource AccentBrush}"/>

        <!-- Status -->
        <TextBlock x:Name="TxtStatus" Grid.Row="7" HorizontalAlignment="Center" FontWeight="SemiBold"
                   Margin="0,10,0,0" Foreground="{DynamicResource SubTextBrush}"/>

        <!-- Taxa de upload (vazio quando nao esta transferindo) -->
        <TextBlock x:Name="TxtRate" Grid.Row="8" HorizontalAlignment="Center" FontSize="12"
                   Margin="0,4,0,0" Foreground="{DynamicResource SubTextBrush}"/>

        <!-- Footer -->
        <Grid Grid.Row="9" Margin="0,12,0,0">
            <TextBlock x:Name="TxtHint" Foreground="{DynamicResource SubTextBrush}" VerticalAlignment="Center"/>
            <Button x:Name="BtnCfg" Content="Settings" Width="130" Height="34" HorizontalAlignment="Right" Click="BtnCfg_Click"/>
        </Grid>
    </Grid>
</Window>
