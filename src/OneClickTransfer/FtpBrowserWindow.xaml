<Window x:Class="OneClickTransfer.FtpBrowserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Choose FTP folder" Height="470" Width="470"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{DynamicResource BgBrush}" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="LblCur" Grid.Row="0" Foreground="{DynamicResource SubTextBrush}"
                   TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
        <ListBox x:Name="Lb" Grid.Row="1" FontSize="14" MouseDoubleClick="Lb_DoubleClick"/>
        <TextBlock x:Name="LblHint" Grid.Row="2" Foreground="{DynamicResource SubTextBrush}"
                   FontSize="11.5" Margin="0,8,0,0"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnSelect" Style="{StaticResource AccentButton}" Width="200" Height="34" Click="Select_Click"/>
            <Button x:Name="BtnCancel" Width="100" Height="34" Margin="10,0,0,0" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
